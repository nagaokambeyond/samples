<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN" "codegen/mybatis-generator-config_1_0.dtd" >
<generatorConfiguration>
    <context id="local"  targetRuntime="MyBatis3">
        <!-- 生成するMapperに@Mapperアノテーションを付与するプラグイン -->
        <plugin type="org.mybatis.generator.plugins.MapperAnnotationPlugin"/>
        <commentGenerator>
            <property name="addRemarkComments" value="true"/>
            <property name="suppressDate" value="true"/>
        </commentGenerator>
        <!-- 接続先DB情報 -->
        <jdbcConnection driverClass="org.h2.Driver"
                        connectionURL="jdbc:h2:mem:mybatis_generator;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DB_CLOSE_DELAY=-1;INIT=RUNSCRIPT FROM 'src/main/resources/generator-schema.sql'"
                        userId="sa"
                        password="" />

        <!-- Model(Entity)作成先 -->
        <modelGenerator targetPackage="com.example.demo.mybatis.generator.entity"
                        targetProject="src/main/java" />
        <!-- Mapper.xml作成先 -->
        <sqlMapGenerator targetPackage="com.example.demo.mybatis.generator.mapper"
                         targetProject="src/main/resources" />
        <!-- Mapper.java作成先 -->
        <clientGenerator targetPackage="com.example.demo.mybatis.generator.mapper"
                         targetProject="src/main/java"
                         type="XMLMAPPER" />

        <!-- 生成対象テーブル -->
        <table tableName="book" domainObjectName="BookEntity" mapperName="BookMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="publisher" domainObjectName="PublisherEntity" mapperName="PublisherMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="book_genre" domainObjectName="BookGenreEntity" mapperName="BookGenreMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="supplier" domainObjectName="SupplierEntity" mapperName="SupplierMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="store" domainObjectName="StoreEntity" mapperName="StoreMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="purchase_invoice" domainObjectName="PurchaseOrderEntity" mapperName="PurchaseOrderMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
            <columnOverride
                    column="purchase_invoice_type"
                    property="purchaseInvoiceType"
                    javaType="com.example.demo.data.domain.PurchaseInvoiceType"
                    typeHandler="com.example.demo.mybatis.typehandler.PurchaseInvoiceTypeHandler"/>
        </table>
        <table tableName="purchase_invoice_detail" domainObjectName="PurchaseOrderDetailEntity" mapperName="PurchaseOrderDetailMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="book_stock" domainObjectName="BookStockEntity" mapperName="BookStockMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
        </table>
        <table tableName="book_stock_movement" domainObjectName="BookStockMovementEntity" mapperName="BookStockMovementMapper">
            <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
            <columnOverride
                    column="movement_type"
                    property="movementType"
                    javaType="com.example.demo.data.domain.BookStockMovementType"
                    typeHandler="com.example.demo.mybatis.typehandler.BookStockMovementTypeHandler"/>
            <columnOverride
                    column="source_type"
                    property="sourceType"
                    javaType="com.example.demo.data.domain.BookStockMovementSourceType"
                    typeHandler="com.example.demo.mybatis.typehandler.BookStockMovementSourceTypeHandler"/>
        </table>
    </context>
</generatorConfiguration>
