<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN" "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd" >
<generatorConfiguration>
    <context id="local"  targetRuntime="MyBatis3">
        <!-- 生成するMapperに@Mapperアノテーションを付与するプラグイン -->
        <plugin type="org.mybatis.generator.plugins.MapperAnnotationPlugin"/>
        <commentGenerator>
            <property name="addRemarkComments" value="true"/>
        </commentGenerator>
        <!-- 接続先DB情報 -->
        <jdbcConnection driverClass="org.h2.Driver"
                        connectionURL="jdbc:h2:mem:mybatis_generator;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DB_CLOSE_DELAY=-1;INIT=RUNSCRIPT FROM 'src/main/resources/generator-schema.sql'"
                        userId="sa"
                        password="" />

        <!-- Model(Entity)作成先 -->
        <modelGenerator targetPackage="com.example.demo.mybatis.generator.entity"
                        targetProject="src/main/java" />
        <!-- Mapper.xml作成先 -->
        <sqlMapGenerator targetPackage="com.example.demo.mybatis.generator.mapper"
                         targetProject="src/main/resources" />
        <!-- Mapper.java作成先 -->
        <clientGenerator targetPackage="com.example.demo.mybatis.generator.mapper"
                         targetProject="src/main/java"
                         type="XMLMAPPER" />

        <!-- 生成対象テーブル -->
        <table tableName="book" domainObjectName="BookEntity" mapperName="BookMapper">
        </table>
    </context>
</generatorConfiguration>
